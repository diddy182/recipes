        "1 pound crabmeat",
        "1 large egg",
        "¼ cup mayonnaise",
        "1 tablespoon Dijon mustard",
        "1 tablespoon Worcestershire sauce",
        "1 cup crushed Ritz crackers",
        "¼ cup melted butter",
        "1 teaspoon Old Bay seasoning",
        "Juice of ½ lemon",
        "1 teaspoon salt"
      ]
    }
  ],
  "instructions": [
